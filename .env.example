# =============================================================================
# AJKMart — Environment Variables Template
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in each value below
#   3. Encrypt into vault:  bash scripts/vault-setup.sh
#   4. Delete .env (the vault scripts/.env.enc is the safe version to commit)
#
# OR — use the interactive wizard which does all of this for you:
#   bash scripts/vault-setup.sh
# =============================================================================

# ── DATABASE ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Get from Neon, Supabase, Railway, etc.
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ── JWT / AUTH SECRETS ────────────────────────────────────────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
ADMIN_JWT_SECRET=
ADMIN_REFRESH_SECRET=
ADMIN_SECRET=
ADMIN_ACCESS_TOKEN_SECRET=
ADMIN_REFRESH_TOKEN_SECRET=
ADMIN_CSRF_SECRET=
VENDOR_JWT_SECRET=
RIDER_JWT_SECRET=
ERROR_REPORT_HMAC_SECRET=
ENCRYPTION_MASTER_KEY=

# ── ADMIN SEED (first admin account) ─────────────────────────────────────────
ADMIN_SEED_USERNAME=superadmin
ADMIN_SEED_EMAIL=admin@ajkmart.com
ADMIN_SEED_NAME=Super Admin
ADMIN_SEED_PASSWORD=

# ── PORTS & URLS ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
APP_BASE_URL=https://yourapp.replit.app
FRONTEND_URL=https://yourapp.replit.app
CLIENT_URL=https://yourapp.replit.app
ADMIN_BASE_URL=https://yourapp.replit.app/admin
ALLOWED_ORIGINS=https://yourapp.replit.app
JWT_ISSUER=ajkmart

# ── REDIS (rate limiting — required in production) ───────────────────────────
# Get free Redis from Upstash: https://upstash.com
# Format: redis://default:password@host:port
REDIS_URL=

# ── FILE STORAGE (S3-compatible — required in production) ────────────────────
# Use DigitalOcean Spaces, Cloudflare R2, AWS S3, or Backblaze B2
STORAGE_BUCKET_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET_NAME=
STORAGE_REGION=us-east-1

# ── SMS OTP (Twilio) ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── EMAIL (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SMTP_HOST=smtp.sendgrid.net

# ── FIREBASE (push notifications) ────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── MAPS ─────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── WEB PUSH (VAPID) ─────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=

# ── ERROR TRACKING (Sentry — optional) ───────────────────────────────────────
SENTRY_DSN=
SENTRY_WEBHOOK_SECRET=

# ── SECURITY ─────────────────────────────────────────────────────────────────
ADMIN_LEGACY_AUTH_DISABLED=false
ADMIN_PASSWORD_RESET_TOKEN_TTL_MIN=60

# ── VITE (frontend build) ─────────────────────────────────────────────────────
VITE_API_PROXY_TARGET=http://127.0.0.1:5000
VITE_API_BASE_URL=https://yourapp.replit.app
