modules = ["nodejs-20", "python-3.11"]

# --- DEPLOYMENT SETTINGS ---
[deployment]
run = ["pnpm", "start"]
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

# --- NIX CONFIG (Strict Mode) ---
[nix]
channel = "stable-24_05"
guessImports = false # Isse Replit khud se kachra workflows nahi banayega

[workflows]
runButton = "Project"

# --- MAIN WORKFLOW (The Master Switch) ---
[[workflows.workflow]]
name = "Setup"
mode = "sequential"
author = "user"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run decrypt-env"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Setup"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Panel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Vendor App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rider App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Customer App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Setup"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

# --- INDIVIDUAL CLEAN WORKFLOWS ---

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run decrypt-env -- --auto; [ -d node_modules ] || pnpm install; PORT=5000 pnpm --filter @workspace/api-server run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Admin Panel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run decrypt-env -- --auto; PORT=3000 BASE_PATH=/admin/ pnpm --filter @workspace/admin run dev"
waitForPort = 3000

[[workflows.workflow]]
name = "Vendor App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run decrypt-env -- --auto; PORT=3001 pnpm --filter @workspace/vendor-app run dev"
waitForPort = 3001

[[workflows.workflow]]
name = "Rider App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run decrypt-env -- --auto; PORT=3002 pnpm --filter @workspace/rider-app run dev"
waitForPort = 3002

[[workflows.workflow]]
name = "Customer App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run decrypt-env -- --auto; PORT=20716 pnpm --filter @workspace/ajkmart run dev:web"

[[workflows.workflow]]
name = "Setup"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run decrypt-env"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm typecheck"

[workflows.workflow.metadata]
isValidation = true

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 3003
externalPort = 5173

[[ports]]
localPort = 3004
externalPort = 4200

[[ports]]
localPort = 3005
externalPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 20716
externalPort = 3003

[[ports]]
localPort = 20717
externalPort = 6800

# --- ENVIRONMENT CONFIG ---
[agent]
expertMode = true

[userenv.shared]
VITE_API_PROXY_TARGET = "http://127.0.0.1:5000"
NODE_ENV = "development"
PORT = "5000"
ADMIN_DEV_PORT = "3000"
VENDOR_DEV_PORT = "3001"
RIDER_DEV_PORT = "3002"
EXPO_DEV_PORT = "20716"
JWT_ISSUER = "ajkmart-dev"
ADMIN_SEED_USERNAME = "superadmin"
ADMIN_SEED_EMAIL = "admin@ajkmart.com"
ADMIN_SEED_NAME = "Super Admin"
ADMIN_SEED_PASSWORD = "Admin@123"
# Keep all your other SECRET keys below this line as they were
LOG_LEVEL = "debug"

[userenv.development]
JWT_SECRET = "dev-jwt-secret-replace-before-prod-min32chars!!"
ADMIN_JWT_SECRET = "dev-admin-jwt-secret-replace-before-prod-min32!!"
ADMIN_REFRESH_SECRET = "dev-admin-refresh-secret-replace-before-prod-x!!"
ADMIN_SECRET = "dev-admin-secret-replace-before-prod-min32chars!!"
ADMIN_ACCESS_TOKEN_SECRET = "dev-admin-access-token-secret-replace-prod-32c!!"
ADMIN_REFRESH_TOKEN_SECRET = "dev-admin-refresh-token-secret-replace-prod-32c!!"
ADMIN_CSRF_SECRET = "dev-admin-csrf-secret-replace-before-prod-min32!!"
VENDOR_JWT_SECRET = "dev-vendor-jwt-secret-replace-before-prod-min32!!"
RIDER_JWT_SECRET = "dev-rider-jwt-secret-replace-before-prod-min32c!!"
ERROR_REPORT_HMAC_SECRET = "dev-error-report-hmac-secret-replace-before-prod!!"
ADMIN_LEGACY_AUTH_DISABLED = "false"
ADMIN_PASSWORD_RESET_TOKEN_TTL_MIN = "60"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
