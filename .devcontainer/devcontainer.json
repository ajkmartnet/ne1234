{
  "name": "AJKMart Super-App",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bullseye",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20",
      "nvmVersion": "latest"
    }
  },

  "postCreateCommand": "npm install -g pnpm@10 && bash scripts/setup.sh",

  "forwardPorts": [5000, 3000, 3001, 3002, 20716],
  "portsAttributes": {
    "5000": { "label": "API Server", "onAutoForward": "notify" },
    "3000": { "label": "Admin Panel", "onAutoForward": "silent" },
    "3001": { "label": "Vendor App", "onAutoForward": "silent" },
    "3002": { "label": "Rider App", "onAutoForward": "silent" },
    "20716": { "label": "Customer App (Expo Web)", "onAutoForward": "silent" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "drizzle-team.drizzle-vscode"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  },

  "remoteEnv": {
    "NODE_ENV": "development",
    "PORT": "5000",
    "VITE_API_PROXY_TARGET": "http://127.0.0.1:5000"
  }
}
