modules = ["nodejs-20", "python-3.11"]

# --- DEPLOYMENT SETTINGS ---
[deployment]
run = ["pnpm", "start"]
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

# --- NIX CONFIG (Strict Mode) ---
[nix]
channel = "stable-24_05"
guessImports = false     # Isse Replit khud se kachra workflows nahi banayega

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Panel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Vendor App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rider App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Customer App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Admin Panel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 BASE_PATH=/admin/ pnpm --filter @workspace/admin run dev"
waitForPort = 3000

[[workflows.workflow]]
name = "Vendor App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 pnpm --filter @workspace/vendor-app run dev"
waitForPort = 3001

[[workflows.workflow]]
name = "Rider App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3002 pnpm --filter @workspace/rider-app run dev"
waitForPort = 3002

[[workflows.workflow]]
name = "Customer App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CI=1 EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID PORT=20716 pnpm --filter @workspace/ajkmart run dev:web"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "flock -x /tmp/ajkmart-install.lock pnpm install --no-frozen-lockfile; PORT=5000 pnpm --filter @workspace/api-server run dev"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 3003
externalPort = 4200

[[ports]]
localPort = 3004
externalPort = 5173

[[ports]]
localPort = 3005
externalPort = 6000

[[ports]]
localPort = 3006
externalPort = 5000

[[ports]]
localPort = 3007
externalPort = 6800

[[ports]]
localPort = 3008
externalPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 8008

[[ports]]
localPort = 20716
externalPort = 8080

[[ports]]
localPort = 20717
externalPort = 3003

# --- ENVIRONMENT CONFIG ---
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[userenv.shared]
VITE_API_PROXY_TARGET = "http://127.0.0.1:5000"
NODE_ENV = "development"
PORT = "5000"
ADMIN_DEV_PORT = "3000"
VENDOR_DEV_PORT = "3001"
RIDER_DEV_PORT = "3002"
EXPO_DEV_PORT = "20716"
JWT_ISSUER = "ajkmart-dev"
ADMIN_SEED_USERNAME = "superadmin"
ADMIN_SEED_EMAIL = "admin@ajkmart.com"
ADMIN_SEED_NAME = "Super Admin"
ADMIN_SEED_PASSWORD = "Admin@123"
# Keep all your other SECRET keys below this line as they were
LOG_LEVEL = "debug"

