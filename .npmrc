auto-install-peers=false
strict-peer-dependencies=false

# Hoist key CLI binaries to root node_modules/.bin so they work in all workflows,
# VPS shells, Codespaces terminals, and GitHub Actions — without needing PATH tricks.
public-hoist-pattern[]=tsx
public-hoist-pattern[]=vite
public-hoist-pattern[]=expo
public-hoist-pattern[]=tsc
public-hoist-pattern[]=drizzle-kit
public-hoist-pattern[]=concurrently
